variable "aws_region" {
  type        = string
  default     = "us-east-1"
  description = "The target region for resource provisioning."
}

variable "environment" {
  type        = string
  default     = "development"
  description = "Deployment environment name."
}

variable "authorized_bucket_name" {
  type        = string
  default     = "sentinel-authorized-data-001"
  description = "Name of the compliant S3 bucket."
}
